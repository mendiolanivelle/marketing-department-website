{
	admin off
	auto_https off
}

:{$PORT:3000} {
	root * /srv
	encode gzip

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	@notAssets {
		not path /assets/*
	}
	header @notAssets Cache-Control "no-cache, no-store, must-revalidate"

	try_files {path} /index.html
	file_server
}
