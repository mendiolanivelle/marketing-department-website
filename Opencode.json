{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".vite/**",
      ".next/**",
      "coverage/**",
      "*.log",
      "*.csv",
      "*.zip",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock"
    ]
  }
}